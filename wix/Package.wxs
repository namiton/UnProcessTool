<?xml version="1.0" encoding="utf-8"?>
<!-- UnProcessTool MSI 定義 (WiX v5)
     per-user インストール: LocalAppData\Programs\UnProcessTool + HKCU レジストリのみ。UAC 不要。
     コンテキストメニュー登録もインストーラが行い、アンインストールで自動削除される。 -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <?ifndef ProductVersion ?>
    <?define ProductVersion = "1.0.0" ?>
  <?endif?>

  <Package Name="UnProcessTool"
           Manufacturer="namiton"
           Version="$(var.ProductVersion)"
           UpgradeCode="C409C0DB-9F03-455A-A1FB-0BA8B0A8424C"
           Scope="perUser"
           Language="1041"
           Codepage="932"
           Compressed="yes">

    <SummaryInformation Description="UnProcessTool - ファイル/フォルダをロックしているプロセスを特定して終了するツール" />

    <MajorUpgrade DowngradeErrorMessage="新しいバージョンが既にインストールされています。" />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="UnProcessTool" />
      </Directory>
    </StandardDirectory>

    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">

      <!-- per-user インストールのため各ファイルコンポーネントの KeyPath は HKCU レジストリ値にする (ICE38 対応)。
           レジストリ KeyPath + ファイル同居コンポーネントは GUID 自動生成不可 (WIX0230) のため明示指定 -->
      <Component Id="MainScript" Guid="AA3FC215-2EA4-4026-8BEA-A5D117C27854">
        <RegistryValue Root="HKCU" Key="Software\namiton\UnProcessTool\Components" Name="MainScript" Type="integer" Value="1" KeyPath="yes" />
        <File Id="UnProcessToolPs1" Source="..\UnProcessTool.ps1" />
        <RemoveFolder Id="RemoveInstallFolder" On="uninstall" />
      </Component>

      <Component Id="InstallMenuScript" Guid="7A2EC48F-8073-4A32-AE80-2E456F82415C">
        <RegistryValue Root="HKCU" Key="Software\namiton\UnProcessTool\Components" Name="InstallMenuScript" Type="integer" Value="1" KeyPath="yes" />
        <File Id="InstallContextMenuPs1" Source="..\Install-ContextMenu.ps1" />
      </Component>

      <Component Id="UninstallMenuScript" Guid="3DFBD727-D889-4248-82FF-4C2B79045C3D">
        <RegistryValue Root="HKCU" Key="Software\namiton\UnProcessTool\Components" Name="UninstallMenuScript" Type="integer" Value="1" KeyPath="yes" />
        <File Id="UninstallContextMenuPs1" Source="..\Uninstall-ContextMenu.ps1" />
      </Component>

      <Component Id="ReadmeFile" Guid="62F06B59-5B81-471D-83C9-08B8ED3A2604">
        <RegistryValue Root="HKCU" Key="Software\namiton\UnProcessTool\Components" Name="ReadmeFile" Type="integer" Value="1" KeyPath="yes" />
        <File Id="ReadmeMd" Source="..\README.md" />
      </Component>

      <!-- 右クリックメニュー: 全ファイル (*) -->
      <Component Id="ContextMenuAllFiles">
        <RegistryKey Root="HKCU" Key="Software\Classes\*\shell\UnProcessTool">
          <RegistryValue Type="string" Value="ロックしているプロセスを調査 (UnProcessTool)" KeyPath="yes" />
          <RegistryValue Name="Icon" Type="string" Value="taskmgr.exe" />
          <RegistryKey Key="command">
            <RegistryValue Type="string" Value="powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]UnProcessTool.ps1&quot; -Pause -Path &quot;%1&quot;" />
          </RegistryKey>
        </RegistryKey>
      </Component>

      <!-- 右クリックメニュー: フォルダ -->
      <Component Id="ContextMenuDirectory">
        <RegistryKey Root="HKCU" Key="Software\Classes\Directory\shell\UnProcessTool">
          <RegistryValue Type="string" Value="ロックしているプロセスを調査 (UnProcessTool)" KeyPath="yes" />
          <RegistryValue Name="Icon" Type="string" Value="taskmgr.exe" />
          <RegistryKey Key="command">
            <RegistryValue Type="string" Value="powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]UnProcessTool.ps1&quot; -Pause -Path &quot;%1&quot;" />
          </RegistryKey>
        </RegistryKey>
      </Component>

    </ComponentGroup>

    <Feature Id="Main" Title="UnProcessTool">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

  </Package>
</Wix>
